# ─── Supabase Self-Hosted Secrets ────────────────────────────────────
# CHANGE THESE for any non-local deployment.
# The values below are Supabase's official demo defaults, safe for local dev only.

POSTGRES_PASSWORD=your-super-secret-and-long-postgres-password
JWT_SECRET=your-super-secret-jwt-token-with-at-least-32-characters-long
JWT_EXPIRY=3600

# Legacy HS256-signed JWTs (generated from JWT_SECRET above)
